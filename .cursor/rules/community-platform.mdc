## Database schema

### `profiles` table
```sql
create table profiles (
  id           uuid primary key references auth.users(id) on delete cascade,
  username     text unique not null,
  full_name    text not null,
  headline     text,                          -- e.g. "Creative Director · 15yr"
  bio          text,
  avatar_url   text,
  location     text,                          -- City, Country
  timezone     text,                          -- IANA timezone string
  website_url  text,
  linkedin_url text,

  -- Structured identity
  discipline   text not null,                 -- enum: creative | strategy | technology | production | marketing
  seniority    text,                          -- enum: junior | mid | senior | lead | executive
  work_type    text[],                        -- array: freelance | full-time | consulting | advisory
  availability text,                          -- enum: available | open | unavailable
  skills       text[],                        -- free tags: "brand strategy", "motion design", etc.
  tools        text[],                        -- free tags: "Figma", "After Effects", etc.
  industries   text[],                        -- free tags: "beauty", "fintech", etc.
  looking_for  text,                          -- short free-text: "brand partnerships, senior roles"

  -- Search
  search_vector tsvector generated always as (
    to_tsvector('english',
      coalesce(full_name, '') || ' ' ||
      coalesce(headline, '') || ' ' ||
      coalesce(bio, '') || ' ' ||
      coalesce(array_to_string(skills, ' '), '') || ' ' ||
      coalesce(array_to_string(tools, ' '), '') || ' ' ||
      coalesce(array_to_string(industries, ' '), '')
    )
  ) stored,

  -- Meta
  is_featured  boolean default false,
  member_since timestamptz default now(),
  updated_at   timestamptz default now()
);

create index profiles_search_idx on profiles using gin(search_vector);
create index profiles_discipline_idx on profiles(discipline);
create index profiles_availability_idx on profiles(availability);
create index profiles_skills_idx on profiles using gin(skills);
create index profiles_tools_idx on profiles using gin(tools);
```

### `applications` table
```sql
create table applications (
  id           uuid primary key default gen_random_uuid(),
  email        text not null unique,
  full_name    text not null,
  linkedin_url text,
  website_url  text,
  discipline   text not null,
  headline     text not null,         -- "What do you do in one sentence?"
  motivation   text not null,         -- "Why do you want to join?"
  referral     text,                  -- How did you hear about us?
  status       text default 'pending', -- pending | approved | rejected | invited
  reviewed_by  uuid references profiles(id),
  reviewed_at  timestamptz,
  invite_token text unique,
  invite_sent_at timestamptz,
  invite_expires_at timestamptz,
  created_at   timestamptz default now()
);
```

### `opportunities` table
```sql
create table opportunities (
  id             uuid primary key default gen_random_uuid(),
  posted_by      uuid references profiles(id) on delete cascade,
  title          text not null,
  type           text not null,        -- enum: job | project | collab | event
  description    text not null,
  skills_needed  text[],
  location_type  text,                 -- remote | hybrid | on-site
  location       text,
  compensation   text,                 -- free text: "€80k", "Day rate", "Revenue share"
  engagement     text,                 -- full-time | part-time | one-off | ongoing
  deadline       date,
  is_active      boolean default true,
  created_at     timestamptz default now(),
  updated_at     timestamptz default now()
);
```

### Row-level security policies
```sql
-- Profiles: only approved members can read
alter table profiles enable row level security;

create policy "Members can read all profiles"
  on profiles for select
  using (auth.uid() in (
    select id from profiles
  ));

create policy "Members can update own profile"
  on profiles for update
  using (auth.uid() = id);

-- Opportunities: only authenticated members
alter table opportunities enable row level security;

create policy "Members can read opportunities"
  on opportunities for select
  using (auth.uid() in (select id from profiles));

create policy "Members can insert opportunities"
  on opportunities for insert
  with check (auth.uid() = posted_by);

create policy "Members can update own opportunities"
  on opportunities for update
  using (auth.uid() = posted_by);

-- Applications: admin only (use service role in admin routes)
alter table applications enable row level security;
```

