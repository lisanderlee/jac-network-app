## Invite flow

```
applicant submits form
       ↓
application saved (status: pending)
       ↓
admin reviews in /admin/applications
       ↓
admin clicks "Approve + Invite"
       ↓
server action:
  - sets status = "invited"
  - generates crypto invite token (24hr expiry)
  - sends InviteEmail via Resend
       ↓
applicant clicks invite link → /invite/[token]
       ↓
validates token (not expired, not used)
       ↓
supabase.auth.signUp() with their email
       ↓
profile creation form (pre-filled from application)
       ↓
profile saved → token invalidated → redirect to /directory
```

### Server action for approval
```typescript
// app/(admin)/applications/[id]/actions.ts
'use server'

import { createAdminClient } from '@/lib/supabase/admin'
import { resend } from '@/lib/resend'
import { InviteEmail } from '@/emails/InviteEmail'
import crypto from 'crypto'

export async function approveAndInvite(applicationId: string) {
  const supabase = createAdminClient()

  const token = crypto.randomBytes(32).toString('hex')
  const expiresAt = new Date(Date.now() + 24 * 60 * 60 * 1000) // 24hr

  const { data: application } = await supabase
    .from('applications')
    .update({
      status: 'invited',
      invite_token: token,
      invite_sent_at: new Date().toISOString(),
      invite_expires_at: expiresAt.toISOString(),
    })
    .eq('id', applicationId)
    .select()
    .single()

  await resend.emails.send({
    from: 'team@yourplatform.com',
    to: application.email,
    subject: 'Your invitation to [Platform Name]',
    react: InviteEmail({
      name: application.full_name,
      inviteUrl: `${process.env.NEXT_PUBLIC_APP_URL}/invite/${token}`,
    }),
  })
}
```

